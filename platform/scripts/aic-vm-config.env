# VM configuration — sourced by platform/scripts/aic and compatibility shims
# Override project/zone/name or remote repo layout as needed:
# AIC_VM_REPO_PATH=/srv/aic/repo  (compose-on-VM SSH commands run from here)
#
# Update ZONE if the instance is ever recreated in a different zone.
AIC_VM_PROJECT="${AIC_VM_PROJECT:-ai-for-industry}"
AIC_VM_NAME="${AIC_VM_NAME:-aic-dev}"
AIC_VM_ZONE="${AIC_VM_ZONE:-asia-southeast1-a}"
